{
  "version": 2,
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "api/health.js", "use": "@vercel/node" },
    { "src": "api/catalog-status.js", "use": "@vercel/node" },
    { "src": "api/catalog-sync.js", "use": "@vercel/node" },
    { "src": "api/search.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/catalog-status", "dest": "/api/catalog-status.js" },
    { "src": "/api/catalog-sync", "dest": "/api/catalog-sync.js" },
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/catalog-sync", "schedule": "0 3 * * *" }
  ]
}
